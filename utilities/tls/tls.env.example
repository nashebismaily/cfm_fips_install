#!/usr/bin/env bash
# ==============================================================================
# Manual TLS utility configuration for CFM / NiFi / NiFi Registry on FIPS hosts
# ==============================================================================

# Output location. This can be shared or copied between hosts after generation.
export TLS_OUTPUT_DIR="${TLS_OUTPUT_DIR:-/root/cfm_tls_artifacts}"

# Host inventory file. One row per host/certificate.
export TLS_HOSTS_FILE="${TLS_HOSTS_FILE:-./hosts.csv}"

# Certificate identity defaults.
export TLS_ORG="${TLS_ORG:-Cloudera Demo}"
export TLS_OU="${TLS_OU:-CFM}"
export TLS_CITY="${TLS_CITY:-Demo City}"
export TLS_STATE="${TLS_STATE:-Demo State}"
export TLS_COUNTRY="${TLS_COUNTRY:-US}"

# Key/CSR settings. RSA 3072 + SHA256 are safe defaults for FIPS environments.
export TLS_KEY_ALGORITHM="${TLS_KEY_ALGORITHM:-RSA}"
export TLS_RSA_BITS="${TLS_RSA_BITS:-3072}"
export TLS_DIGEST="${TLS_DIGEST:-sha256}"

# Store settings. PKCS12 is supported by NiFi/NiFi Registry and avoids JKS.
# Optional BCFKS conversion is attempted if keytool/provider supports it.
export TLS_KEYSTORE_TYPE="${TLS_KEYSTORE_TYPE:-PKCS12}"
export TLS_TRUSTSTORE_TYPE="${TLS_TRUSTSTORE_TYPE:-PKCS12}"
export TLS_CREATE_BCFKS="${TLS_CREATE_BCFKS:-false}"

# Passwords. Change these before running in a real environment.
export TLS_KEY_PASSWORD="${TLS_KEY_PASSWORD:-ChangeMe_KeyPass_2026}"
export TLS_KEYSTORE_PASSWORD="${TLS_KEYSTORE_PASSWORD:-ChangeMe_KeyStore_2026}"
export TLS_TRUSTSTORE_PASSWORD="${TLS_TRUSTSTORE_PASSWORD:-ChangeMe_TrustStore_2026}"

# CA files used by 04_build_stores.sh after your CA signs the CSRs.
# Put returned host certs under: $TLS_OUTPUT_DIR/signed/<host_id>.crt
# Put issuing CA chain here, leaf issuer first if your CA provides a chain.
export TLS_CA_CHAIN_FILE="${TLS_CA_CHAIN_FILE:-$TLS_OUTPUT_DIR/ca/ca-chain.pem}"

# Optional local demo CA settings. Do not use the demo CA for production.
export TLS_DEMO_CA_CN="${TLS_DEMO_CA_CN:-CFM Demo Root CA}"
export TLS_DEMO_CA_DAYS="${TLS_DEMO_CA_DAYS:-825}"

# Java/FIPS module paths for optional BCFKS conversion.
export JAVA_HOME="${JAVA_HOME:-/usr/lib/jvm/java-11-openjdk}"
export TLS_FIPS_JAR_DIR="${TLS_FIPS_JAR_DIR:-/opt/cloudera/fips}"
export TLS_CCJ_JAR="${TLS_CCJ_JAR:-$TLS_FIPS_JAR_DIR/ccj-3.0.2.1.jar}"
export TLS_BCTLS_JAR="${TLS_BCTLS_JAR:-$TLS_FIPS_JAR_DIR/bctls-safelogic.jar}"
export TLS_CCJ_MODULE="${TLS_CCJ_MODULE:-com.safelogic.cryptocomply.fips.core}"
export TLS_BCTLS_MODULE="${TLS_BCTLS_MODULE:-bctls.safelogic}"
