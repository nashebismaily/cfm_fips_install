#!/usr/bin/env bash
# Manual TLS utility configuration for CFM / NiFi / NiFi Registry.
# This utility is intentionally NOT Cloudera Auto-TLS.

# Root output directory for generated TLS artifacts
export TLS_WORKDIR='/root/cfm_tls_artifacts'

# Host list input
export TLS_HOSTS_FILE='./hosts.csv'

# Key/cert settings. RSA 3072 + SHA256 is a safe default for FIPS environments.
export TLS_KEY_ALGORITHM='RSA'
export TLS_KEY_SIZE='3072'
export TLS_DIGEST='sha256'
export TLS_CERT_DAYS='825'

# Store type. Use PKCS12, not JKS, for FIPS-friendly Java/NiFi usage.
export TLS_STORE_TYPE='PKCS12'

# Passwords. Quote these values if you use special characters.
# To keep shell handling simple, alphanumeric passwords are recommended.
export TLS_KEY_PASSWORD='ChangeMeKeyPass2026'
export TLS_KEYSTORE_PASSWORD='ChangeMeKeyStore2026'
export TLS_TRUSTSTORE_PASSWORD='ChangeMeTrustStore2026'

# Demo CA settings. Used only if you run 02_create_demo_ca.sh and 03_sign_csrs_with_demo_ca.sh.
export TLS_DEMO_CA_CN='CFM Demo Internal CA'
export TLS_DEMO_CA_DAYS='3650'
export TLS_DEMO_CA_KEY_PASSWORD='ChangeMeDemoCA2026'

# Java/keytool path
export JAVA_HOME='${JAVA_HOME:-/usr/lib/jvm/java-11-openjdk}'
export KEYTOOL="${JAVA_HOME}/bin/keytool"
