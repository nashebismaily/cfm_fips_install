#!/usr/bin/env bash
# ==============================================================================
# Cloudera Manager Auto-TLS Use Case 3 utility configuration
# Use Case 3 = Auto-TLS with existing CA-signed host certificates.
# You can either:
#   1. Generate private keys and CSRs with these utilities, send CSRs to your CA,
#      then drop returned certs into AUTO_TLS_CERTS_DIR.
#   2. Skip CSR generation and place customer-provided keys/certs directly into
#      AUTO_TLS_KEYS_DIR and AUTO_TLS_CERTS_DIR.
# ==============================================================================

# ---- Working directories on the Cloudera Manager server ----
export AUTO_TLS_WORKDIR='/tmp/auto-tls'
export AUTO_TLS_KEYS_DIR="${AUTO_TLS_WORKDIR}/keys"
export AUTO_TLS_CSRS_DIR="${AUTO_TLS_WORKDIR}/csrs"
export AUTO_TLS_CERTS_DIR="${AUTO_TLS_WORKDIR}/certs"
export AUTO_TLS_CA_CERTS_DIR="${AUTO_TLS_WORKDIR}/ca-certs"
export AUTO_TLS_PAYLOAD_DIR="${AUTO_TLS_WORKDIR}/payload"

# This is the location CM will use for Auto-TLS artifacts after generateCmca.
# Cloudera recommends a path CM can access and that does not already contain old truststores.
export AUTO_TLS_LOCATION='/opt/cloudera/AutoTLS'

# ---- Host inventory ----
# CSV columns: hostname,cn,san_dns,san_ip
# san_dns and san_ip are optional pipe-separated lists.
export HOSTS_CSV='./hosts.csv'

# ---- CA chain and optional trusted CA bundle ----
# ca-chain.pem must contain the issuing chain expected by CM. Include intermediates/root
# in the correct order per your CA process.
export AUTO_TLS_CA_CHAIN_FILE="${AUTO_TLS_CA_CERTS_DIR}/ca-chain.pem"
# Optional. Leave empty unless you want CM to distribute additional trusted CA certs.
export AUTO_TLS_TRUSTED_CA_CERTS_FILE=''

# ---- Password files required by generateCmca ----
# Cloudera requires passwords more than 12 characters and no special characters.
export AUTO_TLS_KEYSTORE_PASSWORD='ChangeMeLongEnough123'
export AUTO_TLS_TRUSTSTORE_PASSWORD='ChangeMeTrust123'
export AUTO_TLS_KEY_PASSWORD_FILE="${AUTO_TLS_KEYS_DIR}/key.pwd"
export AUTO_TLS_TRUSTSTORE_PASSWORD_FILE="${AUTO_TLS_CA_CERTS_DIR}/truststore.pwd"

# ---- CSR/key generation mode ----
# Set GENERATE_KEYS_AND_CSRS=false when the customer provides the private keys and signed certs.
export GENERATE_KEYS_AND_CSRS='true'
# If true, existing generated keys/CSRs will be overwritten.
export OVERWRITE_KEYS_AND_CSRS='false'
export TLS_KEY_ALGORITHM='rsa'
export TLS_RSA_BITS='4096'
export TLS_SIGNATURE_DIGEST='sha256'
export TLS_CERT_DAYS='365'
# Subject DN values used when generating CSRs. CN comes from hosts.csv.
export TLS_SUBJECT_O='Cloudera Test'
export TLS_SUBJECT_OU='Platform'
export TLS_SUBJECT_L='City'
export TLS_SUBJECT_ST='State'
export TLS_SUBJECT_C='US'

# ---- Cloudera Manager API ----
export CM_HOST_FQDN='ip-10-0-0-64.us-east-2.compute.internal'
# Use http/7180 before CM TLS is enabled. Use https/7183 if converting from existing TLS.
export CM_API_SCHEME='http'
export CM_API_PORT='7180'
export CM_API_USER='admin'
export CM_API_PASS='admin'
export CM_API_VERSION='v41'
export CONFIGURE_ALL_SERVICES='true'

# ---- SSH settings for Auto-TLS API ----
# Use either SSH_PASSWORD or SSH_PRIVATE_KEY_FILE. Passwordless sudo is still required
# for the user across all cluster hosts.
export SSH_PORT='22'
export SSH_USER='root'
export SSH_PASSWORD=''
export SSH_PRIVATE_KEY_FILE=''

# ---- Filenames expected by the utilities/API ----
# For each hostname in hosts.csv, expected files are:
#   ${AUTO_TLS_KEYS_DIR}/<hostname>-key.pem
#   ${AUTO_TLS_CERTS_DIR}/<hostname>.pem
#   ${AUTO_TLS_CSRS_DIR}/<hostname>.csr
export HOST_KEY_SUFFIX='-key.pem'
export HOST_CERT_SUFFIX='.pem'
export HOST_CSR_SUFFIX='.csr'
